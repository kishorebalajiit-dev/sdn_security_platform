SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-too
JWT_ACCESS_MINUTES=480

# Supabase PostgreSQL — replace with your project connection string
# Session pooler (recommended for server apps):
# DATABASE_URL=postgresql+psycopg2://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+psycopg2://securenet:securenet@postgres:5432/securenet_ai
SUPABASE_SSL=1

AUTO_CREATE_TABLES=1
SEED_DATABASE=1
RATELIMIT_STORAGE_URI=memory://

# Frontend
VITE_API_BASE_URL=http://localhost:5000/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Blockchain / SDN (optional)
GANACHE_URL=http://127.0.0.1:7545
RYU_CONTROLLER_URL=http://127.0.0.1:8080
